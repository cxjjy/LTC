generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES
  PM
  DELIVERY
  FINANCE
  SUPER_ADMIN
  PROJECT_MANAGER
  VIEWER
}

enum LeadStatus {
  NEW
  FOLLOWING
  CONVERTED
  CLOSED
}

enum OpportunityStage {
  DISCOVERY
  REQUIREMENT
  PROPOSAL
  QUOTATION
  NEGOTIATION
  WON
  LOST
}

enum ProjectStatus {
  INITIATING
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELED
}

enum ContractStatus {
  ACTIVE
  TERMINATED
}

enum DeliveryStatus {
  NOT_STARTED
  IN_PROGRESS
  ACCEPTED
  DELAYED
  CANCELED
}

enum CostCategory {
  PROCUREMENT
  LABOR
  TRAVEL
  OUTSOURCING
  OTHER
}

enum ReceivableStatus {
  PENDING
  PARTIAL
  RECEIVED
  OVERDUE
}

enum ContractDirection {
  SALES
  PURCHASE
}

enum InvoiceDirection {
  OUTPUT
  INPUT
}

enum PaymentDirection {
  INFLOW
  OUTFLOW
}

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  STATUS_CHANGE
  CONVERT
  LOGIN
}

enum EntityType {
  USER
  ROLE
  PERMISSION
  CUSTOMER
  LEAD
  OPPORTUNITY
  PROJECT
  CONTRACT
  DELIVERY
  COST
  RECEIVABLE
  AUDIT_LOG
}

model WeeklyReport {
  id              BigInt    @id @default(autoincrement())
  userId          String    @map("user_id") @db.VarChar(191)
  weekStart       DateTime  @map("week_start") @db.Date
  weekEnd         DateTime  @map("week_end") @db.Date
  status          String    @default("draft") @db.VarChar(20)
  summary         String?   @db.Text
  submittedAt     DateTime? @map("submitted_at")
  lastSavedAt     DateTime? @map("last_saved_at")
  reviewNote      String?   @map("review_note") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by") @db.VarChar(191)
  returnNote      String?   @map("return_note") @db.Text
  returnedAt      DateTime? @map("returned_at")
  returnedBy      String?   @map("returned_by") @db.VarChar(191)
  overdueMarkedAt DateTime? @map("overdue_marked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([userId, weekStart], map: "uk_user_week")
  @@index([weekStart], map: "idx_week_start")
  @@index([status], map: "idx_status")
  @@map("weekly_reports")
}

model WeeklyReportItem {
  id                   BigInt    @id @default(autoincrement())
  reportId             BigInt    @map("report_id")
  itemType             String    @map("item_type") @db.VarChar(20)
  content              String    @db.Text
  priority             String    @default("medium") @db.VarChar(20)
  needCoordination     Boolean   @default(false) @map("need_coordination")
  expectedFinishAt     DateTime? @map("expected_finish_at") @db.Date
  impactNote           String?   @map("impact_note") @db.Text
  relatedProjectId     String?   @map("related_project_id") @db.VarChar(191)
  relatedOpportunityId String?   @map("related_opportunity_id") @db.VarChar(191)
  sortOrder            Int       @default(0) @map("sort_order")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([reportId], map: "idx_report_id")
  @@index([itemType], map: "idx_item_type")
  @@index([relatedProjectId], map: "idx_related_project_id")
  @@index([relatedOpportunityId], map: "idx_related_opportunity_id")
  @@map("weekly_report_items")
}

model ProjectWeeklySnapshot {
  id                 BigInt   @id @default(autoincrement())
  projectId          String   @map("project_id") @db.VarChar(191)
  weekStart          DateTime @map("week_start") @db.Date
  weekEnd            DateTime @map("week_end") @db.Date
  progressSummary    String?  @map("progress_summary") @db.Text
  costDelta          Decimal  @default(0) @map("cost_delta") @db.Decimal(18, 2)
  receivableDelta    Decimal  @default(0) @map("receivable_delta") @db.Decimal(18, 2)
  riskFlag           Boolean  @default(false) @map("risk_flag")
  riskCount          Int      @default(0) @map("risk_count")
  trafficLightStatus String   @default("green") @map("traffic_light_status") @db.VarChar(20)
  weeklyActions      String?  @map("weekly_actions") @db.Text
  ownerNote          String?  @map("owner_note") @db.Text
  generatedAt        DateTime @default(now()) @map("generated_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([projectId, weekStart], map: "uk_project_week")
  @@index([weekStart], map: "idx_week_start")
  @@index([riskFlag], map: "idx_risk_flag")
  @@map("project_weekly_snapshots")
}

model WeeklyReportAuditRef {
  id             BigInt   @id @default(autoincrement())
  entityType     String   @map("entity_type") @db.VarChar(50)
  entityId       String   @map("entity_id") @db.VarChar(191)
  action         String   @db.VarChar(50)
  operatorUserId String   @map("operator_user_id") @db.VarChar(191)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId], map: "idx_entity")
  @@index([operatorUserId], map: "idx_operator")
  @@index([createdAt], map: "idx_created_at")
  @@map("weekly_report_audit_refs")
}

model WeeklyReportReminder {
  id           BigInt   @id @default(autoincrement())
  weekStart    DateTime @map("week_start") @db.Date
  reportId     BigInt?  @map("report_id")
  targetUserId String   @map("target_user_id") @db.VarChar(191)
  message      String?  @db.VarChar(255)
  status       String   @default("pending") @db.VarChar(20)
  remindedBy   String   @map("reminded_by") @db.VarChar(191)
  remindedAt   DateTime @default(now()) @map("reminded_at")

  @@index([weekStart, targetUserId], map: "idx_week_target")
  @@index([reportId], map: "idx_report_id")
  @@index([status], map: "idx_status")
  @@index([remindedBy], map: "idx_reminded_by")
  @@map("weekly_report_reminders")
}

model WeeklyReportSuggestion {
  id                   BigInt    @id @default(autoincrement())
  userId               String    @map("user_id") @db.VarChar(191)
  weekStart            DateTime  @map("week_start") @db.Date
  sectionType          String    @map("section_type") @db.VarChar(20)
  sourceType           String    @map("source_type") @db.VarChar(50)
  sourceRef            String?   @map("source_ref") @db.VarChar(191)
  reason               String?   @db.VarChar(255)
  content              String    @db.Text
  relatedProjectId     String?   @map("related_project_id") @db.VarChar(191)
  relatedOpportunityId String?   @map("related_opportunity_id") @db.VarChar(191)
  confidenceScore      Decimal   @default(0) @map("confidence_score") @db.Decimal(5, 2)
  status               String    @default("pending") @db.VarChar(20)
  extraPayload         Json?     @map("extra_payload")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([userId, weekStart, status], map: "idx_user_week_status")
  @@index([sourceType], map: "idx_source_type")
  @@index([relatedProjectId], map: "idx_related_project_id")
  @@index([relatedOpportunityId], map: "idx_related_opportunity_id")
  @@map("weekly_report_suggestions")
}

model WeeklyTask {
  id             BigInt   @id @default(autoincrement())
  type           String   @db.VarChar(30)
  content        String   @db.Text
  projectId      String?  @map("project_id") @db.VarChar(191)
  sourceReportId BigInt   @map("source_report_id")
  sourceItemId   BigInt?  @map("source_item_id")
  creatorId      String   @map("creator_id") @db.VarChar(191)
  assigneeId     String   @map("assignee_id") @db.VarChar(191)
  status         String   @default("open") @db.VarChar(20)
  priority       String   @default("medium") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([type, status], map: "idx_type_status")
  @@index([projectId], map: "idx_project_id")
  @@index([sourceReportId], map: "idx_source_report_id")
  @@index([sourceItemId], map: "idx_source_item_id")
  @@index([assigneeId, status], map: "idx_assignee_status")
  @@map("weekly_tasks")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique @db.VarChar(100)
  dingUserId   String?  @unique @map("ding_user_id") @db.VarChar(191)
  displayName  String   @map("display_name") @db.VarChar(100)
  passwordHash String   @db.VarChar(255)
  name         String   @db.VarChar(100)
  role         UserRole @default(ADMIN)
  email        String?  @unique @db.VarChar(191)
  phone        String?  @db.VarChar(50)
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userRoles    UserRoleAssignment[]
  authBindings AuthBinding[]

  @@index([role])
  @@index([isActive])
  @@index([isDeleted])
}

model AuthBinding {
  id             String   @id @default(cuid())
  userId         String
  provider       String   @db.VarChar(50)
  providerUserId String   @db.VarChar(191)
  unionId        String?  @db.VarChar(191)
  openId         String?  @db.VarChar(191)
  nick           String?  @db.VarChar(100)
  avatar         String?  @db.VarChar(500)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_bindings")
}

model Role {
  id              String                    @id @default(cuid())
  code            String                    @unique @db.VarChar(100)
  name            String                    @db.VarChar(100)
  description     String?                   @db.VarChar(255)
  isSystem        Boolean                   @default(false)
  isDeleted       Boolean                   @default(false)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  userRoles       UserRoleAssignment[]
  rolePermissions RolePermissionAssignment[]

  @@map("roles")
  @@index([isDeleted])
}

model Permission {
  id              String                    @id @default(cuid())
  code            String                    @unique @db.VarChar(100)
  name            String                    @db.VarChar(100)
  module          String                    @db.VarChar(100)
  action          String                    @db.VarChar(50)
  description     String?                   @db.VarChar(255)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  rolePermissions RolePermissionAssignment[]

  @@index([module])
  @@index([action])
  @@map("permissions")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermissionAssignment {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Customer {
  id           String   @id @default(cuid())
  code         String   @unique @db.VarChar(40)
  name         String   @db.VarChar(200)
  industry     String?  @db.VarChar(100)
  contactName  String?  @db.VarChar(100)
  contactPhone String?  @db.VarChar(50)
  address      String?  @db.VarChar(255)
  remark       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String   @db.VarChar(191)
  updatedBy    String   @db.VarChar(191)
  isDeleted    Boolean  @default(false)

  leads         Lead[]
  opportunities Opportunity[]
  projects      Project[]
  contracts     Contract[]
  deliveries    Delivery[]
  costs         Cost[]
  receivables   Receivable[]

  @@index([name, isDeleted])
  @@index([isDeleted, createdAt])
}

model Supplier {
  id           String   @id @default(cuid())
  code         String   @unique @db.VarChar(40)
  name         String   @db.VarChar(200)
  contactName  String?  @map("contact_name") @db.VarChar(100)
  contactPhone String?  @map("contact_phone") @db.VarChar(50)
  address      String?  @db.VarChar(255)
  remark       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String   @map("created_by") @db.VarChar(191)
  updatedBy    String   @map("updated_by") @db.VarChar(191)
  isDeleted    Boolean  @default(false) @map("is_deleted")

  projectLinks ProjectSupplier[]
  contracts    Contract[]

  @@index([name, isDeleted], map: "idx_supplier_name_deleted")
  @@map("suppliers")
}

model ProjectSupplier {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id") @db.VarChar(191)
  supplierId  String   @map("supplier_id") @db.VarChar(191)
  role        String?  @db.VarChar(100)
  remark      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by") @db.VarChar(191)
  updatedBy   String   @map("updated_by") @db.VarChar(191)
  isDeleted   Boolean  @default(false) @map("is_deleted")

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([projectId, supplierId], map: "uk_project_supplier")
  @@index([supplierId, isDeleted], map: "idx_supplier_deleted")
  @@index([projectId, isDeleted], map: "idx_project_deleted")
  @@map("project_suppliers")
}

model Lead {
  id                String     @id @default(cuid())
  code              String     @unique @db.VarChar(40)
  customerId        String
  title             String     @db.VarChar(200)
  source            String?    @db.VarChar(100)
  contactName       String?    @db.VarChar(100)
  contactPhone      String?    @db.VarChar(50)
  expectedAmount    Decimal?   @db.Decimal(18, 2)
  expectedCloseDate DateTime?
  latestFollowUpAt  DateTime?
  description       String?    @db.Text
  status            LeadStatus @default(NEW)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdBy         String     @db.VarChar(191)
  updatedBy         String     @db.VarChar(191)
  isDeleted         Boolean    @default(false)

  customer    Customer     @relation(fields: [customerId], references: [id])
  opportunity Opportunity?

  @@index([customerId, isDeleted])
  @@index([status, isDeleted])
}

model Opportunity {
  id               String           @id @default(cuid())
  code             String           @unique @db.VarChar(40)
  customerId       String
  leadId           String?          @unique
  name             String           @db.VarChar(200)
  description      String?          @db.Text
  amount           Decimal          @db.Decimal(18, 2)
  estimatedRevenue Decimal          @default(0) @db.Decimal(18, 2)
  estimatedLaborCost Decimal        @default(0) @db.Decimal(18, 2)
  estimatedOutsourceCost Decimal    @default(0) @db.Decimal(18, 2)
  estimatedProcurementCost Decimal  @default(0) @db.Decimal(18, 2)
  estimatedTravelCost Decimal       @default(0) @db.Decimal(18, 2)
  estimatedOtherCost Decimal        @default(0) @db.Decimal(18, 2)
  estimatedTotalCost Decimal        @default(0) @db.Decimal(18, 2)
  estimatedProfit Decimal           @default(0) @db.Decimal(18, 2)
  estimatedProfitMargin Decimal     @default(0) @db.Decimal(18, 4)
  expectedSignDate DateTime?
  winRate          Int              @default(0)
  stage            OpportunityStage @default(DISCOVERY)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        String           @db.VarChar(191)
  updatedBy        String           @db.VarChar(191)
  isDeleted        Boolean          @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
  lead     Lead?    @relation(fields: [leadId], references: [id])
  projects Project[]

  @@index([customerId, isDeleted])
  @@index([stage, isDeleted])
}

model Project {
  id               String        @id @default(cuid())
  code             String        @unique @db.VarChar(40)
  customerId       String
  opportunityId    String
  name             String        @db.VarChar(200)
  description      String?       @db.Text
  budgetAmount     Decimal?      @db.Decimal(18, 2)
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  deliveryMode     String?       @map("delivery_mode") @db.VarChar(50)
  region           String?       @db.VarChar(100)
  ownerName        String?       @map("owner_name") @db.VarChar(100)
  status           ProjectStatus @default(INITIATING)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  createdBy        String        @db.VarChar(191)
  updatedBy        String        @db.VarChar(191)
  isDeleted        Boolean       @default(false)

  customer     Customer     @relation(fields: [customerId], references: [id])
  opportunity  Opportunity  @relation(fields: [opportunityId], references: [id])
  contracts    Contract[]
  deliveries   Delivery[]
  costs        Cost[]
  receivables  Receivable[]
  suppliers    ProjectSupplier[]

  @@index([customerId, isDeleted])
  @@index([opportunityId, isDeleted])
  @@index([status, isDeleted])
}

model Contract {
  id                String                   @id @default(cuid())
  code              String                   @unique @db.VarChar(40)
  customerId        String
  projectId         String
  supplierId        String?                  @map("supplier_id") @db.VarChar(191)
  direction         ContractDirection        @default(SALES)
  name              String                   @db.VarChar(200)
  contractAmount    Decimal                  @db.Decimal(18, 2)
  signedDate        DateTime?
  effectiveDate     DateTime?
  endDate           DateTime?
  status            ContractStatus           @default(ACTIVE)
  description       String?                  @db.Text
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdBy         String                   @db.VarChar(191)
  updatedBy         String                   @db.VarChar(191)
  isDeleted         Boolean                  @default(false)

  customer          Customer                 @relation(fields: [customerId], references: [id])
  project           Project                  @relation(fields: [projectId], references: [id])
  supplier          Supplier?                @relation(fields: [supplierId], references: [id])
  receivables       Receivable[]
  attachments       ContractAttachment[]
  @@index([customerId, isDeleted])
  @@index([projectId, isDeleted])
  @@index([supplierId, isDeleted])
  @@index([direction, isDeleted])
  @@index([status, isDeleted])
}

model ContractAttachment {
  id         String   @id @default(cuid())
  contractId String
  fileName   String   @db.VarChar(255)
  fileUrl    String   @db.VarChar(500)
  filePath   String   @db.VarChar(500)
  fileSize   Int
  fileType   String   @db.VarChar(100)
  createdAt  DateTime @default(now())
  uploadedBy String   @db.VarChar(191)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
}

model BizAttachment {
  id         String   @id @default(cuid())
  bizType    String   @map("biz_type") @db.VarChar(50)
  bizId      String   @map("biz_id") @db.VarChar(191)
  projectId  String?  @map("project_id") @db.VarChar(191)
  contractId String?  @map("contract_id") @db.VarChar(191)
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url") @db.VarChar(500)
  filePath   String   @map("file_path") @db.VarChar(500)
  fileSize   Int      @map("file_size")
  mimeType   String?  @map("mime_type") @db.VarChar(100)
  uploadedBy String   @map("uploaded_by") @db.VarChar(191)
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  remark     String?  @db.Text
  status     String   @default("active") @db.VarChar(20)

  @@index([bizType, bizId], map: "idx_biz_type_id")
  @@index([projectId, bizType], map: "idx_project_biz_type")
  @@index([contractId, bizType], map: "idx_contract_biz_type")
  @@index([uploadedAt], map: "idx_uploaded_at")
  @@map("biz_attachments")
}

model InvoiceRecord {
  id            String   @id @default(cuid())
  contractId    String   @map("contract_id") @db.VarChar(191)
  projectId     String?  @map("project_id") @db.VarChar(191)
  direction     InvoiceDirection @default(OUTPUT)
  invoiceNo     String   @map("invoice_no") @db.VarChar(100)
  invoiceType   String   @map("invoice_type") @db.VarChar(50)
  invoiceAmount Decimal  @map("invoice_amount") @db.Decimal(18, 2)
  invoiceDate   DateTime @map("invoice_date") @db.Date
  payerName     String?  @map("payer_name") @db.VarChar(200)
  status        String   @default("issued") @db.VarChar(20)
  attachmentId  String?  @map("attachment_id") @db.VarChar(191)
  createdBy     String   @map("created_by") @db.VarChar(191)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([contractId, invoiceNo], map: "uk_contract_invoice_no")
  @@index([projectId], map: "idx_project_id")
  @@index([direction], map: "idx_direction")
  @@index([status], map: "idx_status")
  @@index([invoiceDate], map: "idx_invoice_date")
  @@map("invoice_records")
}

model PaymentRecord {
  id            String   @id @default(cuid())
  contractId    String   @map("contract_id") @db.VarChar(191)
  projectId     String?  @map("project_id") @db.VarChar(191)
  direction     PaymentDirection @default(INFLOW)
  paymentAmount Decimal  @map("payment_amount") @db.Decimal(18, 2)
  paymentDate   DateTime @map("payment_date") @db.Date
  paymentMethod String?  @map("payment_method") @db.VarChar(50)
  payerName     String?  @map("payer_name") @db.VarChar(200)
  sourceType    String   @default("manual") @map("source_type") @db.VarChar(30)
  sourceRef     String?  @map("source_ref") @db.VarChar(191)
  remark        String?  @db.Text
  createdBy     String   @map("created_by") @db.VarChar(191)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([contractId, paymentDate], map: "idx_contract_payment_date")
  @@index([projectId], map: "idx_project_id")
  @@index([direction], map: "idx_direction")
  @@index([sourceType], map: "idx_source_type")
  @@map("payment_records")
}

model OpportunityContractApproval {
  id                String   @id @default(cuid())
  opportunityId     String   @map("opportunity_id") @db.VarChar(191)
  applicantId       String   @map("applicant_id") @db.VarChar(191)
  approverId        String   @map("approver_id") @db.VarChar(191)
  status            String   @default("pending") @db.VarChar(20)
  approvalComment   String?  @map("approval_comment") @db.Text
  submittedAt       DateTime @default(now()) @map("submitted_at")
  approvedAt        DateTime? @map("approved_at")
  rejectedAt        DateTime? @map("rejected_at")
  createdContractId String?  @map("created_contract_id") @db.VarChar(191)
  snapshotJson      Json?    @map("snapshot_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([opportunityId, status], map: "idx_opportunity_status")
  @@index([applicantId, status], map: "idx_applicant_status")
  @@index([approverId, status], map: "idx_approver_status")
  @@index([submittedAt], map: "idx_submitted_at")
  @@map("opportunity_contract_approvals")
}

model Delivery {
  id              String         @id @default(cuid())
  code            String         @unique @db.VarChar(40)
  customerId      String
  projectId       String
  title           String         @db.VarChar(200)
  description     String?        @db.Text
  ownerName       String?        @db.VarChar(100)
  plannedDate     DateTime?
  actualDate      DateTime?
  acceptanceDate  DateTime?
  status          DeliveryStatus @default(NOT_STARTED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String         @db.VarChar(191)
  updatedBy       String         @db.VarChar(191)
  isDeleted       Boolean        @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  @@index([customerId, isDeleted])
  @@index([projectId, isDeleted])
  @@index([status, isDeleted])
}

model Cost {
  id          String       @id @default(cuid())
  code        String       @unique @db.VarChar(40)
  customerId  String
  projectId   String
  title       String       @db.VarChar(200)
  category    CostCategory
  amount      Decimal      @db.Decimal(18, 2)
  occurredAt  DateTime
  description String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String       @db.VarChar(191)
  updatedBy   String       @db.VarChar(191)
  isDeleted   Boolean      @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  @@index([customerId, isDeleted])
  @@index([projectId, isDeleted])
  @@index([category, isDeleted])
}

model Receivable {
  id             String           @id @default(cuid())
  code           String           @unique @db.VarChar(40)
  customerId     String
  projectId      String
  contractId     String
  title          String           @db.VarChar(200)
  amountDue      Decimal          @db.Decimal(18, 2)
  amountReceived Decimal          @default(0) @db.Decimal(18, 2)
  dueDate        DateTime
  receivedDate   DateTime?
  status         ReceivableStatus @default(PENDING)
  description    String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      String           @db.VarChar(191)
  updatedBy      String           @db.VarChar(191)
  isDeleted      Boolean          @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([customerId, isDeleted])
  @@index([projectId, isDeleted])
  @@index([contractId, isDeleted])
  @@index([status, isDeleted])
}

model AuditLog {
  id         String      @id @default(cuid())
  entityType EntityType
  entityId   String      @db.VarChar(191)
  entityCode String?     @db.VarChar(40)
  action     AuditAction
  message    String      @db.VarChar(255)
  actorId    String      @db.VarChar(191)
  payload    Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorId])
}

model CodeSequence {
  id           String     @id @default(cuid())
  entityType   EntityType
  prefix       String     @db.VarChar(20)
  year         Int
  currentValue Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([entityType, year])
}
